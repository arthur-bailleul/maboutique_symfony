{% extends 'base.html.twig' %}

{% block title %}Modifier le mot de passe{% endblock %}

{% block body %}

<div class="container py-5" style="max-width: 450px;">

    <div class="card shadow-sm border-0">
        <div class="card-body">

            <h2 class="text-center mb-3">Mot de passe</h2>

            <p class="text-center">
                <a href="{{ path('account') }}" class="text-decoration-none small">
                    ← Retour à mon compte
                </a>
            </p>

            <hr>

            {{ form_start(form) }}

                <div class="mb-3">
                    {{ form_row(form.oldPassword, {
                        label: 'Mot de passe actuel',
                        attr: { class: 'form-control' }
                    }) }}
                </div>

                <div class="mb-3">
                    {{ form_row(form.newPassword, {
                        label: 'Nouveau mot de passe',
                        attr: { class: 'form-control' }
                    }) }}
                </div>

                <div class="mb-3">
                    {{ form_row(form.confirmNewPassword, {
                        label: 'Confirmer le mot de passe',
                        attr: { class: 'form-control' }
                    }) }}
                </div>

                <div class="d-grid mt-3">
                    {{ form_row(form.submit, {
                        attr: { class: 'btn btn-primary w-100' }
                    }) }}
                </div>

            {{ form_end(form) }}

        </div>
    </div>

</div>

{% endblock %}
