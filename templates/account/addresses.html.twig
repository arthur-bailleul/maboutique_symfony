{% extends 'base.html.twig' %}

{% block title %}Mes adresses - Mon compte{% endblock %}

{% block body %}

<div class="container py-5" style="max-width: 800px;">

    <!-- Fil d'ariane pour revenir facilement au compte -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('account') }}" class="text-decoration-none">Mon compte</a></li>
            <li class="breadcrumb-item active" aria-current="page">Mes adresses</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Mes adresses de livraison</h2>
        <a href="{{ path('account_address_add') }}" class="btn btn-primary shadow-sm">Ajouter une adresse</a>
    </div>

    {% if app.user.addresses|length == 0 %}
        <div class="card shadow border-0 text-center py-5">
            <div class="card-body">
                <p class="text-muted mb-3">Vous n'avez pas encore enregistré d'adresse de livraison.</p>
                <a href="{{ path('account_address_add') }}" class="btn btn-dark">Créer ma première adresse</a>
            </div>
        </div>
    {% else %}
        <div class="row g-3">
            {# app is a huge var, app.user is the entity #}
            {% for address in app.user.addresses %}
                <div class="col-md-6">
                    <div class="card h-100 shadow border-0">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div>
                                <h5 class="card-title text-capitalize">
                                    {{ address.firstname }} {{ address.lastname }}
                                </h5>
                                {% if address.company %}
                                    <h6 class="card-subtitle mb-2 text-muted">Entreprise: {{ address.company }}</h6>
                                {% endif %}
                                <p class="card-text text-muted mb-1">Adresse: {{ address.address }}</p>
                                <p class="card-text text-muted mb-1">Code postal: {{ address.postal }} {{ address.city }}</p>
                                <p class="card-text text-muted mb-3">Pays: {{ address.country }}</p>
                                <p class="card-text small text-muted">
                                    Tel: {{ address.phone }}
                                </p>
                            </div>

                            <div class="mt-3 pt-3 border-top d-flex justify-content-end gap-2">
                                <a href="{{ path('account_address_edit', { 'id': address.id }) }}" class="btn btn-sm btn-light text-primary border">
                                    Modifier
                                </a>
                                <a href="{{ path('account_address_delete', { 'id': address.id }) }}" class="btn btn-sm btn-light text-danger border" onclick="return confirm('Supprimer cette adresse ?');">
                                    Supprimer
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

</div>

{% endblock %}
