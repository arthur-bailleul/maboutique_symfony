{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}

<div class="container py-5" style="max-width: 600px;">

    <!-- Fil d'ariane pour revenir facilement au compte -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item active" aria-current="page">Mon compte</li>
        </ol>
    </nav>

    <div class="card shadow border-0">
        <div class="card-body">

            <h2 class="mb-3">Mon compte</h2>

            <p class="text-muted mb-4">
                Bienvenue <strong>{{ app.user.firstname }} {{ app.user.lastname }}</strong>
            </p>

            <hr>

            <div class="list-group list-group-flush mt-3">
                <a href="{{ path('changePassword') }}" class="list-group-item list-group-item-action">
                    🔒 Modifier le mot de passe
                </a>

                <a href="{{ path('account_address') }}" class="list-group-item list-group-item-action">
                    📍 Gérer mes adresses
                </a>

                <a href="#" class="list-group-item list-group-item-action">
                    📦 Mes commandes
                </a>
            </div>

        </div>
    </div>

</div>

{% endblock %}
