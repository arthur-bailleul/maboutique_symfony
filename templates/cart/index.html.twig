{% extends 'base.html.twig' %}

{% block title %}Mon Panier{% endblock %}

{% block body %}

<div class="container py-5">

  <h1 class="fw-semibold mb-5">Mon Panier</h1>

  {% if cart|length > 0 %}
    <div class="row g-5 align-items-start">

      <!-- LISTE DES PRODUITS DU PANIER -->
      <div class="col-lg-8">
        <div class="card border-0 shadow rounded-4 overflow-hidden">
          <ul class="list-group list-group-flush">

            {% for id, qty in cart %}
              {% set product = products[id] %}

              <li class="list-group-item p-4">
                <div class="row align-items-center ">

                  <!-- Quantité (Maintenant en premier) -->
                  <div class="col-4 col-md-3 d-flex justify-content-start justify-content-md-center align-items-center">
                    <div class="d-flex align-items-center gap-2">
                      <a href="{{ path('decrease_cart', {'id': id}) }}" class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center fa-solid fa-minus" style="width: 28px; height: 28px;"></a>
                      <span class="fw-semibold">{{ qty }}</span>
                      <a href="{{ path('add_cart', {'id': id}) }}" class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center fa-solid fa-plus" style="width: 28px; height: 28px;"></a>
                    </div>
                  </div>

                  <!-- Image -->
                  <div class="col-3 col-md-2">
                    <div class="ratio ratio-1x1 bg-light rounded-3 overflow-hidden">
                      <img src="/uploads/{{ product.image }}"
                           class="w-100 h-100 object-fit-cover"
                           alt="{{ product.name }}">
                    </div>
                  </div>

                  <!-- Infos -->
                  <div class="col-5 col-md-4">
                    <h6 class="fw-semibold mb-1">
                      {{ product.name }}
                    </h6>
                    <p class="text-muted small mb-0 text-align-center">
                      {# Division par 100 et formatage du prix unitaire #}
                      Prix unitaire : {{ (product.price / 100)|number_format(2, ',', ' ') }} €
                    </p>
                  </div>

                  <!-- Total Item & Suppression -->
                  <div class="col-12 col-md-3 d-flex justify-content-between align-items-center mt-3 mt-md-0">
                    <span class="fw-semibold fs-5">
                      {# Division par 100 et formatage du sous-total de l'article #}
                      {{ ((product.price * qty) / 100)|number_format(2, ',', ' ') }} €
                    </span>
                    <a href="{{ path('remove_cart', {'id': id}) }}" class="text-danger text-decoration-none fs-4 fa-solid fa-trash-can" title="Supprimer"></a>
                  </div>

                </div>
              </li>
            {% endfor %}

          </ul>
        </div>

        <!-- Bouton Vider le panier -->
        <div class="mt-3 text-end">
          <a href="{{ path('clear_cart') }}" class="btn btn-sm btn-outline-danger rounded-3">
            Vider le panier
          </a>
        </div>
      </div>

      <!-- RÉSUMÉ DE LA COMMANDE -->
      <div class="col-lg-4">
        <div class="card border-0 shadow rounded-4 bg-light p-4">
          <h4 class="fw-semibold mb-4">Résumé</h4>

          <div class="d-flex justify-content-between mb-3">
            <span class="text-muted">Articles ({{ quantite }})</span>
            {# Division par 100 pour le total du résumé #}
            <span class="fw-semibold">{{ (total / 100)|number_format(2, ',', ' ') }} €</span>
          </div>
          <div class="d-flex justify-content-between mb-3">
            <span class="text-muted">Livraison</span>
            <span class="text-muted small">Calculé ensuite</span>
          </div>

          <hr class="my-4">

          <div class="d-flex justify-content-between align-items-center mb-4">
            <span class="fs-5 fw-semibold">Total</span>
            {# Division par 100 pour le grand total #}
            <span class="fs-4 fw-bold">{{ (total / 100)|number_format(2, ',', ' ') }} €</span>
          </div>

          <div class="d-flex flex-column gap-2">
            <a href="{{ path('order') }}" class="btn btn-dark rounded-3 py-2 fw-semibold w-100">
              Valider ma commande
            </a>
            <a href="{{ path('products') }}" class="btn btn-outline-dark rounded-3 py-2 w-100">
              Continuer mes achats
            </a>
          </div>
        </div>
      </div>

    </div>

  {% else %}

    <!-- PANIER VIDE -->
    <div class="row">
      <div class="col-md-8 mx-auto text-center py-5 mt-4 bg-light rounded-4 shadow-sm border-0">
        <h3 class="fw-semibold mb-3">Votre panier est vide</h3>
        <p class="text-muted mb-4">Découvrez nos produits et trouvez votre bonheur.</p>
        <a href="{{ path('products') }}" class="btn btn-dark rounded-3 px-4 py-2">
          Voir les produits
        </a>
      </div>
    </div>

  {% endif %}

</div>

{% endblock %}
