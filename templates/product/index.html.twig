{% extends 'base.html.twig' %}

{% block title %}Nos Produits{% endblock %}

{% block body %}

<div class="container py-4">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 fw-semibold">Nos Produits</h1>
  </div>

  <!-- Grid -->
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

    {% for product in products %}

      <div class="col">
        <div class="card h-100 border-0 shadow rounded-4 overflow-hidden">

          <!-- Image -->
          <div class="ratio ratio-4x3 bg-light">
            <img src="/uploads/{{ product.image }}"
                 class="w-100 h-100 object-fit-cover"
                 alt="{{ product.name }}">
          </div>

          <!-- Body -->
          <div class="card-body d-flex flex-column">

            <h5 class="card-title fw-semibold mb-1">
              {{ product.name }}
            </h5>

            {% if product.subtitle %}
              <p class="text-muted small mb-2">
                {{ product.subtitle }}
              </p>
            {% endif %}

            <p class="card-text text-secondary small flex-grow-1">
              {{ product.description|slice(0, 120) ~ '...' }}
            </p>

            <!-- CTA -->
            {# <a href="{{ path('product', product.id)}}" #}
            <a href="/nos-produits/{{ product.id }}"
               class="btn btn-outline-dark btn-sm mt-3 w-100 rounded-3">
              Voir détails
            </a>

          </div>

        </div>
      </div>

    {% endfor %}

  </div>

</div>

{% endblock %}
