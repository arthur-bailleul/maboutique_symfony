{% extends 'base.html.twig' %}

{% block title %}Hello TwigTestController!
{% endblock %}

{% block body %}
	<style>
		.example-wrapper {
			margin: 1em auto;
			max-width: 800px;
			width: 95%;
			font: 18px / 1.5 sans-serif;
		}

		.example-wrapper code {
			background: #F5F5F5;
			padding: 2px 6px;
		}
	</style>



	<div class="example-wrapper">

    <a href="{{ path('app_bonjour')}}">Home</a>

{% set name = 1 %}
{{ name }}
    {{ strong }}
    {{ strong|raw }}
		<h1>Hello
			{{ controller_name }}! ✅</h1>
		<ul>
			{% for index, info in infos %}
				{% if loop.first %}
					<strong>
						<li>

							{{ index }}
							=>
							{{ info|capitalize }}</li>
					</strong>
				{% else %}
					<li>
						{{ index }}
						=>
						{{ info }}</li>
				{% endif %}
			{% endfor %}
		</ul>

	</div>
{% endblock %}
